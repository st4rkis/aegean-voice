PORT=3000
PUBLIC_BASE_URL=https://voice-gateway.aegean.taxi

# Dispatch backend mode: onde | nq
BACKEND_MODE=onde

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=coral
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TEMPERATURE=0.7
OPENAI_RATE_TEXT_INPUT_USD_PER_1M=5
OPENAI_RATE_TEXT_OUTPUT_USD_PER_1M=20
OPENAI_RATE_AUDIO_INPUT_USD_PER_1M=40
OPENAI_RATE_AUDIO_OUTPUT_USD_PER_1M=80
OPENAI_BLEND_USD_PER_1M=45
USD_TO_EUR=0.8456
ASSISTANT_LANGUAGE_MODE=en

# Voice stack mode (current runtime still uses OpenAI realtime path)
VOICE_STACK_MODE=legacy

GREETING_TEXT=Welcome to Aegean Taxi. How can I help you today?
PREP_TEXT=Aegean Taxi. To book fast, please say island, pickup, destination, passengers, and when. For price checks, say your pickup and destination.
RECORDING_NOTICE=Calls may be recorded for quality purposes.

# Optional websocket URL signing (recommended)
WS_SHARED_SECRET=

# ONDE Operator API
ONDE_BASE_URL=https://api-sandbox.onde.app
ONDE_OPERATOR_TOKEN=
ONDE_AUTH_SCHEME=Bearer
ONDE_TIMEOUT_MS=7000
ONDE_ALLOWED_VEHICLE_TYPES=

# NQ backend integration (required when BACKEND_MODE=nq)
NQ_BASE_URL=
NQ_TIMEOUT_MS=7000
NQ_SERVICE_TOKEN=
NQ_CALL_NUMBER_ID=
NQ_COMPANY_ID=
NQ_COMPANY_CODE=
NQ_TRANSCRIPT_ENABLED=true
NQ_PUBLIC_CLIENT_ID=
NQ_PUBLIC_CLIENT_SECRET=

# Optional external place resolver (if empty, internal OpenStreetMap Nominatim resolver is used)
PLACE_RESOLVER_URL=
PLACE_RESOLVER_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=AegeanVoiceResolver/1.0 (ops@aegeantaxi.com)
NOMINATIM_EMAIL=
NOMINATIM_COUNTRY_CODES=gr
NOMINATIM_MIN_INTERVAL_MS=1200
ENABLE_NOMINATIM_FALLBACK=false
POI_DB_PATH=/home/ubuntu/aegean-voice-gateway/data/poi-db.json
ONDE_SERVICE_TYPES_PATH=/home/ubuntu/aegean-voice-gateway/data/service-types.json
ORDER_MEMORY_PATH=/home/ubuntu/aegean-voice-gateway/data/order-memory.json

# Optional WhatsApp sender service
WHATSAPP_PROVIDER=custom
WHATSAPP_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_SEND_PATH=/ai/send-whatsapp
WHATSAPP_META_API_VERSION=v22.0
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_TOKEN=

# Planned V3 providers (for next migration stage)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
